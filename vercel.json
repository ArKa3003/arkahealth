{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["iad1", "sfo1"],
  "functions": {
    "app/api/cds-services/**/*.ts": { "maxDuration": 10 },
    "app/api/ins/**/*.ts": { "maxDuration": 10 }
  },
  "crons": [
    {
      "path": "/api/ins/scheduling/reconcile",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/ins/reference/refresh",
      "schedule": "0 5 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/cds-services",
      "destination": "/api/cds-services"
    },
    {
      "source": "/api/rural/:path*",
      "destination": "/api/rural/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://sandbox.cds-hooks.org; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; upgrade-insecure-requests"
        }
      ]
    }
  ]
}
