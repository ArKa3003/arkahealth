# ARKA Health – Vercel / local environment variables
# Copy to .env.local for local dev; set in Vercel Dashboard for production.

# Canonical site URL (used for sitemap, robots, and metadata).
# Production: https://arkahealth.com or your Vercel URL
# Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://arkahealth.com

# Supabase (shared; ARKA-INS tables use `ins_` prefix — see supabase/migrations/)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: required for `npm run seed:ins` / `reset:ins` (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# ARKA-INS investor / sandbox demos: mock FHIR when prefetch is empty; offline API fallbacks; disable writes.
# For dashboard "Demo" watermark in the browser, also set NEXT_PUBLIC_DEMO_MODE=true.
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false

# Rural Platform (future production integrations)
# TELERADIOLOGY_API_KEY=
# MOBILE_UNIT_SCHEDULING_API_KEY=
# PACS_INTEGRATION_ENDPOINT=
# AI_MARKETPLACE_API_KEY=
# HRSA_GRANTS_API_KEY=
# GEOCODING_API_KEY=

# ARKA-CLIN ML service (Phase 5 — Python XGBoost + SHAP)
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=5000
ML_FALLBACK_ENABLED=true
# FDA Non-Device CDS: when true, the route still ships a card even if ML is unreachable,
# using rules + citations only. REQUIRED behaviour; do not set false in production.
ML_FALLBACK_ENABLED_REASON=fda_criterion_4_independent_review
NEXT_PUBLIC_FDA_DISCLOSURE_VERSION=1.1.0
