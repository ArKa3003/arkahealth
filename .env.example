# ARKA Health – Vercel / local environment variables
# Copy to .env.local for local dev; set in Vercel Dashboard for production.

# Canonical site URL (used for sitemap, robots, and metadata).
# Production: https://arkahealth.com or your Vercel URL
# Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://arkahealth.com

# Demo sign-in (marketing site — single shared demo principal)
# Copy to .env.local; used by POST /api/auth/signin
DEMO_USER_EMAIL=demo@getarka.health
DEMO_USER_PASSWORD=arka-demo-2026
# Signs httpOnly arka_session cookies (min 32 chars in production)
SESSION_SECRET=

# Supabase (shared; ARKA-INS tables use `ins_` prefix — see supabase/migrations/)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: required for `npm run seed:ins` / `reset:ins` (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# ARKA-INS investor / sandbox demos: mock FHIR when prefetch is empty; offline API fallbacks; disable writes.
# For dashboard "Demo" watermark in the browser, also set NEXT_PUBLIC_DEMO_MODE=true.
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false

# Rural Platform (future production integrations)
# TELERADIOLOGY_API_KEY=
# MOBILE_UNIT_SCHEDULING_API_KEY=
# PACS_INTEGRATION_ENDPOINT=
# AI_MARKETPLACE_API_KEY=
# HRSA_GRANTS_API_KEY=
# GEOCODING_API_KEY=

# ARKA-CLIN CDS / ML scoring (Python XGBoost + SHAP)
#
# Vercel production (Dashboard → Settings → Environment Variables):
#   Option A (recommended for shareholder demo): leave ML_SERVICE_URL unset — CDS routes use
#   fast rule-based AIIE fallback (deterministic, no external dependency). Keep ML_FALLBACK_ENABLED=true.
#   Option B (full ML): set ML_SERVICE_URL to your deployed FastAPI HTTPS URL (reachable from iad1).
#   Never set ML_SERVICE_URL=http://localhost:8000 in Production — localhost cannot resolve on Vercel.
#
# Local dev: copy this file to .env.local and set ML_SERVICE_URL=http://localhost:8000 when running
# the Python ML service locally.
#
# ML scoring service. In production set to the deployed FastAPI URL, e.g. https://arka-ml.fly.dev
# If unset/unreachable, the CDS routes fall back to rule-based AIIE scoring (still guideline-anchored).
ML_SERVICE_URL=
ML_SERVICE_TIMEOUT=2500
ML_FALLBACK_ENABLED=true
# FDA Non-Device CDS: when true, the route still ships a card even if ML is unreachable,
# using rules + citations only. REQUIRED behaviour; do not set false in production.
ML_FALLBACK_ENABLED_REASON=fda_criterion_4_independent_review
NEXT_PUBLIC_FDA_DISCLOSURE_VERSION=1.1.0

# Regulatory dashboard: decision-log preview in production (header X-ARKA-REGULATORY-PREVIEW)
ARKA_REGULATORY_PREVIEW_TOKEN=
