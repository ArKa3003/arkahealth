{
  "name": "arkahealth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "type-check": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint --quiet lib/aiie lib/cards lib/coding lib/compliance lib/federated lib/fhir lib/ins lib/lake lib/nlp lib/retrieval lib/viewer lib/server app/api/ins app/api/cds-services app/api/federated components/ins components/shared components/demos/ins components/demos/clin __tests__ scripts/test-cds-sandbox.ts",
    "lint:scope": "tsx scripts/lint-scope-boundary.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:compliance": "vitest run __tests__/compliance",
    "test:sandbox": "tsx scripts/test-cds-sandbox.ts",
    "seed:ins": "tsx --env-file=.env.local scripts/seed-ins-demo-data.ts",
    "seed:rarity": "tsx --env-file=.env.local scripts/seed-rarity-index.ts",
    "refresh:reference-cache": "tsx --env-file=.env.local scripts/refresh-reference-cache.ts",
    "reset:ins": "tsx --env-file=.env.local scripts/reset-ins-demo.ts",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "test:a11y": "npx lighthouse http://localhost:3000 --only-categories=accessibility --output=html --output-path=./.lighthouse/a11y-report.html --chrome-flags='--headless' --no-enable-error-reporting"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
