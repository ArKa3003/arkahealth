    "lint": "next lint",
    "test": "vitest run",
    "test:sandbox": "tsx scripts/test-cds-sandbox.ts",
    "seed:ins": "tsx --env-file=.env.local scripts/seed-ins-demo-data.ts",
    "reset:ins": "tsx --env-file=.env.local scripts/reset-ins-demo.ts",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "test:a11y": "npx lighthouse http://localhost:3000 --only-categories=accessibility --output=html --output-path=./.lighthouse/a11y-report.html --chrome-flags='--headless' --no-enable-error-reporting"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
